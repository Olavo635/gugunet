{
  "namespace": "wqqn1ynamespace",

  "wqqn1ynamespace": {
    "type": "panel",
    "size": [340, 190],
    "layer": 0,
    "anchor_from": "center",
    "anchor_to": "center",
    "controls": [
      {
        "header_panel": {
          "type": "panel",
          "size": ["100%", 18],
          "layer": 2,
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            {
              "header_bg": {
                "type": "image",
                "size": ["100%", "100%"],
                "layer": 4,
                "texture": "textures/dropdown_background2",
                "anchor_from": "top_left",
                "anchor_to": "top_left"
              }
            },
            {
              "title_image": {
                "type": "image",
                "size": [100, 16],
                "offset": [0, -4],
                "layer": 5,
                "texture": "textures/external/minigames-title",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle"
              }
            },
            {
              "close_button@common_buttons.light_content_button": {
                "$default_button_texture": "textures/red_default_button",
                "$hover_button_texture": "textures/red_hover_button",
                "$pressed_button_texture": "textures/red_pressed_button",
                "$default_state_border_visible": false,
                "$hover_state_border_visible": false,
                "$pressed_state_border_visible": false,
                "$pressed_button_name": "button.menu_exit",
                "size": [20, 20],
                "offset": [-3, 2],
                "layer": 5,
                "anchor_from": "top_right",
                "anchor_to": "top_right",
                "$button_text": ""
              }
            }
          ]
        }
      },
      {
        "content_bg": {
          "type": "image",
          "size": ["100%", "100% - 18px"],
          "offset": [0, 18],
          "layer": 3,
          "texture": "textures/background_form",
          "anchor_from": "top_left",
          "anchor_to": "top_left"
        }
      },
      {
        "scrolling_panel@common.scrolling_panel": {
          "size": ["100% - 6px", "100% - 22px"],
          "offset": [0, 20],
          "layer": 4,
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "$show_background": false,
          "$scrolling_content": "wqqn1ynamespace.grid_content",
          "$scroll_size": [3, "100% - 4px"],
          "$scrolling_pane_size": ["100% - 4px", "100% - 2px"],
          "$scrolling_pane_offset": [1, 0],
          "$scroll_bar_right_padding_size": [0, 0]
        }
      }
    ]
  },

  "grid_content": {
    "type": "stack_panel",
    "size": ["100%", "100%"],
    "orientation": "vertical",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "row1": {
          "type": "stack_panel",
          "size": ["100%", "fill"],
          "orientation": "horizontal",
          "controls": [
            {
              "card1@wqqn1ynamespace.minigame_card": {
                "collection_index": 0
              }
            },
            {
              "spacer1": {
                "type": "panel",
                "size": [2, "100%"]
              }
            },
            {
              "card2@wqqn1ynamespace.minigame_card": {
                "collection_index": 1
              }
            },
            {
              "spacer2": {
                "type": "panel",
                "size": [2, "100%"]
              }
            },
            {
              "card3@wqqn1ynamespace.minigame_card": {
                "collection_index": 2
              }
            }
          ]
        }
      },
      {
        "row_spacer": {
          "type": "panel",
          "size": ["100%", 2]
        }
      },
      {
        "row2": {
          "type": "stack_panel",
          "size": ["100%", "fill"],
          "orientation": "horizontal",
          "controls": [
            {
              "card4@wqqn1ynamespace.minigame_card": {
                "collection_index": 3
              }
            },
            {
              "spacer3": {
                "type": "panel",
                "size": [2, "100%"]
              }
            },
            {
              "card5@wqqn1ynamespace.minigame_card": {
                "collection_index": 4
              }
            },
            {
              "spacer4": {
                "type": "panel",
                "size": [2, "100%"]
              }
            },
            {
              "card6@wqqn1ynamespace.minigame_card": {
                "collection_index": 5
              }
            }
          ]
        }
      }
    ]
  },

  "minigame_card": {
    "type": "panel",
    "size": ["fill", "fill"],
    "layer": 4,
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "card_bg": {
          "type": "image",
          "size": ["100%", "100%"],
          "layer": 4,
          "texture": "textures/dropdown_background2",
          "anchor_from": "top_left",
          "anchor_to": "top_left"
        }
      },
      {
        "card_inner": {
          "type": "panel",
          "size": ["100% - 4px", "100%"],
          "offset": [0, 0],
          "layer": 5,
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "controls": [
            {
              "preview_image": {
                "type": "image",
                "size": ["100%", "fill"],
                "layer": 5,
                "texture": "textures/preview_minigame_1",
                "anchor_from": "top_left",
                "anchor_to": "top_left",
                "bindings": [
                  {
                    "binding_type": "collection",
                    "binding_collection_name": "form_buttons",
                    "binding_name": "#form_button_texture",
                    "binding_name_override": "#texture"
                  }
                ]
              }
            },
            {
              "play_button@common_buttons.light_content_button": {
                "$default_button_texture": "textures/green_default",
                "$hover_button_texture": "textures/green_hover",
                "$pressed_button_texture": "textures/green_pressed",
                "$default_state_border_visible": false,
                "$hover_state_border_visible": false,
                "$pressed_state_border_visible": false,
                "$pressed_button_name": "button.form_button_click",
                "size": ["60%", 14],
                "offset": [0, -1],
                "layer": 5,
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "$button_text": "",
                "$button_text_binding_type": "collection",
                "$button_text_grid_collection_name": "form_buttons",
                "$button_text_max_size": ["100%", 10],
                "bindings": [
                  {
                    "binding_type": "collection_details",
                    "binding_collection_name": "form_buttons"
                  }
                ]
              }
            },
            {
              "play_label": {
                "type": "label",
                "text": "Jogar",
                "font_type": "MinecraftTen",
                "font_scale_factor": 0.7,
                "offset": [0, -1],
                "layer": 6,
                "anchor_from": "bottom_middle",
                "anchor_to": "bottom_middle",
                "text_alignment": "center",
                "shadow": false
              }
            }
          ]
        }
      }
    ]
  }
}